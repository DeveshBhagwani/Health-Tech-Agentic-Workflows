@model IEnumerable<PatientTriagePortal.Models.PatientSymptom>

@{
    ViewData["Title"] = "Triage Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary">Triage Dashboard</h2>
    <a asp-action="Index" class="btn btn-outline-primary">+ New Patient</a>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Patient Name</th>
                        <th>Symptoms</th>
                        <th>Triage Level</th>
                        <th>Department</th>
                        <th>Submitted At</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No patient symptoms submitted yet.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@item.PatientName</td>
                                <td><span class="text-truncate d-inline-block" style="max-width: 250px;" title="@item.SymptomDescription">@item.SymptomDescription</span></td>
                                <td>
                                    @{
                                        var badgeClass = item.TriageLevel == "Emergency" ? "bg-danger" :
                                                         item.TriageLevel == "Urgent" ? "bg-warning text-dark" : "bg-success";
                                    }
                                    <span class="badge @badgeClass fs-6 rounded-pill">@item.TriageLevel</span>
                                </td>
                                <td><span class="badge bg-secondary rounded-pill">@item.SuggestedDepartment</span></td>
                                <td class="text-muted small">@item.SubmittedAt.ToLocalTime().ToString("g")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
